# --- Konfiguracja silnika barometru ---
# Skopiuj ten plik do ".env" i uzupelnij wartosci.
# Bez klucza API silnik dziala w TRYBIE PROSTYM (slowa kluczowe, bez AI).

# Klucz API do modelu AI. Po jego wpisaniu silnik automatycznie wlacza TRYB AI.
OPENAI_API_KEY=

# Opcjonalnie: nazwa modelu (domyslnie gpt-4o-mini - tani i szybki).
MODEL=anthropic/claude-sonnet-4.5

# Opcjonalnie: inny endpoint zgodny z OpenAI (np. OpenRouter). Zostaw puste dla OpenAI.
OPENAI_BASE_URL=

# Opcjonalnie: kanal ntfy do powiadomien push. Zostaw puste, aby wylaczyc powiadomienia.
NTFY_KANAL=

# Od jakiej oceny (1-10) wysylac powiadomienie.
PROG_POWIADOMIENIA=7
